# ===== LLM 后端选择 =====
# 'openai' → 使用 OpenAI 兼容 API（DeepSeek 等，性价比最高）
# 'anthropic' → 使用 Anthropic Claude API（需要 ANTHROPIC_API_KEY）
LLM_BACKEND=openai

# ===== OpenAI 兼容 API（LLM_BACKEND=openai 时必填）=====
# DeepSeek: https://api.deepseek.com/v1
# 其他兼容 OpenAI 的 API 只需改 BASE_URL
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.deepseek.com/v1

# ===== Anthropic API（仅 LLM_BACKEND=anthropic 时必填）=====
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514
ANTHROPIC_SIMPLE_MODEL=claude-haiku-3-5-20241022

# ===== MySQL（主应用数据库，只读）=====
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=florist
MYSQL_PASSWORD=your-password
MYSQL_DATABASE=florist

# ===== SQLite（Agent 自身数据）=====
SQLITE_PATH=./data/florist_agent.db

# ===== ChromaDB =====
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./data/chroma

# ===== Server =====
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
API_KEY=florist-agent-api-key-change-me
ADMIN_KEY=florist-admin-key-change-me

# ===== Rate Limiting =====
RATE_LIMIT_USER_PER_MINUTE=60
RATE_LIMIT_IP_PER_MINUTE=120
RATE_LIMIT_GLOBAL_PER_SECOND=50

# ===== Cost Management =====
DAILY_BUDGET_PER_USER_USD=0.50
MONTHLY_BUDGET_TOTAL_USD=100.00

# ===== Logging =====
LOG_LEVEL=INFO
AUDIT_LOG_ENABLED=true
