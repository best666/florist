# ===== Anthropic API =====
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514
ANTHROPIC_SIMPLE_MODEL=claude-haiku-3-5-20241022

# ===== OpenAI API (embeddings only) =====
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMBEDDING_MODEL=text-embedding-3-small

# ===== MySQL (main app database, read-only) =====
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=florist
MYSQL_PASSWORD=florist123
MYSQL_DATABASE=florist

# ===== SQLite (agent data) =====
SQLITE_PATH=./data/florist_agent.db

# ===== ChromaDB =====
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./data/chroma

# ===== Server =====
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
API_KEY=florist-agent-api-key-change-me
ADMIN_KEY=florist-admin-key-change-me

# ===== Rate Limiting =====
RATE_LIMIT_USER_PER_MINUTE=60
RATE_LIMIT_IP_PER_MINUTE=120
RATE_LIMIT_GLOBAL_PER_SECOND=50

# ===== Cost Management =====
DAILY_BUDGET_PER_USER_USD=0.50
MONTHLY_BUDGET_TOTAL_USD=100.00

# ===== Logging =====
LOG_LEVEL=INFO
AUDIT_LOG_ENABLED=true

# ===== OpenTelemetry =====
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
OTEL_ENABLED=false
