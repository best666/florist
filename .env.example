# ============================================================
# Florist 本地开发环境变量（复制为 .env 并填写真实值）
# ============================================================
# .env 文件已被 .gitignore 忽略，不会被提交到仓库

# MySQL 开发密码（与 apps/server/docker-compose.mysql.yml 保持一致）
MYSQL_PASSWORD=change-me-to-a-strong-password
MYSQL_ROOT_PASSWORD=change-me-to-a-strong-root-password

# 可选：测试数据库连接串（用于 pnpm db:init-test）
MYSQL_TEST_URL=mysql://florist:change-me-to-a-strong-password@127.0.0.1:3307/florist_test?connection_limit=5
