COMPOSE_PROJECT_NAME=florist
IMAGE_TAG=latest
SERVER_IMAGE=ghcr.io/your-github-username/florist-server
CLIENT_IMAGE=ghcr.io/your-github-username/florist-client
CLIENT_HTTP_PORT=80

MYSQL_DATABASE=florist
MYSQL_USER=florist
MYSQL_PASSWORD=replace-with-strong-db-password
MYSQL_ROOT_PASSWORD=replace-with-strong-root-password

GLOBAL_PREFIX=api
CORS_ORIGIN=https://florist.example.com
PUBLIC_BASE_URL=https://florist.example.com
DATABASE_ENCRYPTION_KEY=replace-with-prod-32-char-secret-key
BACKUP_CRON=0 0 4 * * *
BACKUP_DIR=var/backups/prod
BACKUP_RETENTION_DAYS=14
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=90

AI_PROXY_BASE_URL=https://api.deepseek.com/v1
AI_PROXY_API_KEY=replace-with-prod-key
AI_PROXY_MODEL=deepseek-v4-flash
AI_AGENT_URL=http://ai-agent:8000
AI_AGENT_API_KEY=florist-agent-api-key-change-me
AI_DAILY_QUOTA=50
AI_CACHE_TTL_MS=600000
WEATHER_CACHE_TTL_MS=1200000
IMAGE_CACHE_TTL_MS=3600000
REQUEST_LOG_RETENTION_DAYS=14

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-prod-admin-password
ADMIN_SESSION_SECRET=replace-with-prod-admin-session-secret
ADMIN_SESSION_TTL_MS=28800000

H5_LOGIN_PHONE=
H5_LOGIN_CODE=
H5_LOGIN_NICKNAME=
WECHAT_MINI_PROGRAM_APP_ID=
WECHAT_MINI_PROGRAM_SECRET=
APP_LOG_LEVELS=warn,error
