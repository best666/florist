PORT=3000
CORS_ORIGIN=https://florist.example.com
GLOBAL_PREFIX=api
DATABASE_URL=mysql://florist:${MYSQL_PASSWORD}@mysql.internal:3306/florist?connection_limit=10
DATABASE_ENCRYPTION_KEY=replace-with-prod-32-char-secret-key
DATABASE_SSL_ENABLED=true
BACKUP_CRON=0 0 4 * * *
BACKUP_DIR=var/backups/prod
BACKUP_RETENTION_DAYS=14
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=90
AI_PROXY_BASE_URL=https://example.com
AI_PROXY_API_KEY=replace-with-prod-key
