PORT=3000
CORS_ORIGIN=https://florist.example.com
GLOBAL_PREFIX=api
DATABASE_URL=mysql://florist:${MYSQL_PASSWORD}@mysql.internal:3306/florist?connection_limit=10
DATABASE_ENCRYPTION_KEY=replace-with-prod-32-char-secret-key
DATABASE_SSL_ENABLED=true
BACKUP_CRON=0 0 4 * * *
BACKUP_DIR=var/backups/prod
BACKUP_RETENTION_DAYS=14
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=90
AI_PROXY_BASE_URL=https://example.com
AI_PROXY_API_KEY=replace-with-prod-key
AI_PROXY_MODEL=gpt-4o-mini
AI_DAILY_QUOTA=50
AI_CACHE_TTL_MS=600000
WEATHER_CACHE_TTL_MS=1200000
IMAGE_CACHE_TTL_MS=3600000
REQUEST_LOG_RETENTION_DAYS=14
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-prod-admin-password
ADMIN_SESSION_SECRET=replace-with-prod-admin-session-secret
ADMIN_SESSION_TTL_MS=28800000
WECHAT_MINI_PROGRAM_APP_ID=replace-with-wechat-mini-program-app-id
WECHAT_MINI_PROGRAM_SECRET=replace-with-wechat-mini-program-secret
APP_LOG_LEVELS=warn,error
EXPOSE_INTERNAL_ERROR_DETAILS=false
