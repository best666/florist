PORT=3000
GLOBAL_PREFIX=api
CORS_ORIGIN=http://localhost:9000
DATABASE_URL=mysql://florist:your-password@127.0.0.1:3307/florist?connection_limit=5
DATABASE_ENCRYPTION_KEY=replace-with-32-char-secret-key
DATABASE_SSL_ENABLED=false
BACKUP_CRON=0 30 3 * * *
BACKUP_DIR=var/backups
BACKUP_RETENTION_DAYS=7
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120
AI_PROXY_BASE_URL=https://example.com
AI_PROXY_API_KEY=replace-with-local-key
AI_PROXY_MODEL=gpt-4o-mini
AI_DAILY_QUOTA=60
AI_CACHE_TTL_MS=600000
WEATHER_CACHE_TTL_MS=900000
IMAGE_CACHE_TTL_MS=3600000
REQUEST_LOG_RETENTION_DAYS=14
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
ADMIN_SESSION_SECRET=replace-with-admin-session-secret
ADMIN_SESSION_TTL_MS=43200000
H5_LOGIN_PHONE=replace-with-local-test-phone
H5_LOGIN_CODE=replace-with-local-test-code
H5_LOGIN_NICKNAME=
WECHAT_MINI_PROGRAM_APP_ID=
WECHAT_MINI_PROGRAM_SECRET=
# 阿里云短信服务（未配置时开发环境直接返回验证码，不发送短信）
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
# 阿里云号码认证服务（PNVS H5 一键登录，未配置时不启用）
PNVS_ACCESS_KEY_ID=
PNVS_ACCESS_KEY_SECRET=
PNVS_SCHEME_CODE=
APP_LOG_LEVELS=log,warn,error,debug,verbose
EXPOSE_INTERNAL_ERROR_DETAILS=true
