generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id                String          @id @db.VarChar(64)
  nickname          String          @db.VarChar(80)
  avatarUrl         String?         @db.VarChar(512)
  profileSignature  String?         @db.VarChar(160)
  loginType         String          @db.VarChar(32)
  wechatOpenIdHash  String?         @unique @db.VarChar(64)
  phoneHash         String?         @unique @db.VarChar(64)
  cityCipher        String?         @db.Text
  phoneMaskedCipher String?         @db.Text
  status            String          @db.VarChar(32)
  lastLoginAt       DateTime?       @db.DateTime(3)
  createdAt         DateTime        @default(now()) @db.DateTime(3)
  updatedAt         DateTime        @updatedAt @db.DateTime(3)
  flowers           Flower[]
  records           CareRecord[]
  undoLogs          RecordUndoLog[]
  members           Member[]
  feedbacks         Feedback[]
  feedbackVotes     FeedbackVote[]
  feedbackComments  FeedbackComment[]
  taxonomyItems     TaxonomyItem[]

  @@index([loginType, updatedAt])
  @@index([status, updatedAt])
}

model Flower {
  id                   String        @id @db.VarChar(64)
  userId               String        @db.VarChar(64)
  name                 String        @db.VarChar(80)
  nickname             String?       @db.VarChar(80)
  category             String        @db.VarChar(32)
  placement            String        @db.VarChar(32)
  careDifficulty       String        @db.VarChar(32)
  careStatus           String        @db.VarChar(32)
  customCategoryId       String?       @db.VarChar(64)
  customPlacementId      String?       @db.VarChar(64)
  customCareDifficultyId String?       @db.VarChar(64)
  customCareStatusId     String?       @db.VarChar(64)
  coverImageId         String?       @db.VarChar(64)
  purchasedAt          DateTime?     @db.DateTime(3)
  priceInCents         Int?
  note                 String?       @db.VarChar(300)
  lastWateredAt        DateTime?     @db.DateTime(3)
  lastFertilizedAt     DateTime?     @db.DateTime(3)
  createdAt            DateTime      @default(now()) @db.DateTime(3)
  updatedAt            DateTime      @updatedAt @db.DateTime(3)
  isDeleted            Boolean       @default(false)
  deletedAt            DateTime?     @db.DateTime(3)
  pendingPurgeAt       DateTime?     @db.DateTime(3)
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  images               FlowerImage[]
  records              CareRecord[]

  @@index([userId, isDeleted, updatedAt])
  @@index([userId, category])
}

model FlowerImage {
  id            String   @id @db.VarChar(64)
  flowerId      String   @db.VarChar(64)
  url           String   @db.VarChar(512)
  compressedUrl String?  @db.VarChar(512)
  createdAt     DateTime @default(now()) @db.DateTime(3)
  flower        Flower   @relation(fields: [flowerId], references: [id], onDelete: Cascade)

  @@index([flowerId])
}

model TaxonomyItem {
  id        String   @id @db.VarChar(64)
  userId    String   @db.VarChar(64)
  type      String   @db.VarChar(16)
  label     String   @db.VarChar(20)
  baseValue String   @db.VarChar(32)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now()) @db.DateTime(3)
  updatedAt DateTime @updatedAt @db.DateTime(3)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, sortOrder])
}

model CareRecord {
  id              String            @id @db.VarChar(64)
  userId          String            @db.VarChar(64)
  flowerId        String            @db.VarChar(64)
  actionType      String            @db.VarChar(32)
  note            String?           @db.VarChar(300)
  cooldownMinutes Int
  createdAt       DateTime          @default(now()) @db.DateTime(3)
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  images          CareRecordImage[]
  flower          Flower            @relation(fields: [flowerId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([flowerId, createdAt])
}

model CareRecordImage {
  id            String     @id @db.VarChar(64)
  recordId      String     @db.VarChar(64)
  url           String     @db.VarChar(512)
  compressedUrl String?    @db.VarChar(512)
  createdAt     DateTime   @default(now()) @db.DateTime(3)
  record        CareRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([recordId])
}

model RecordUndoLog {
  id                String   @id @db.VarChar(64)
  userId            String   @db.VarChar(64)
  recordId          String   @db.VarChar(64)
  flowerId          String   @db.VarChar(64)
  actionType        String   @db.VarChar(32)
  revertedAt        DateTime @default(now()) @db.DateTime(3)
  originalCreatedAt DateTime @db.DateTime(3)
  note              String?  @db.VarChar(300)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revertedAt])
  @@index([flowerId, revertedAt])
}

model Member {
  id           String    @id @db.VarChar(64)
  userId       String    @db.VarChar(64)
  packageType  String    @db.VarChar(32)
  status       String    @db.VarChar(32)
  benefitTypes Json
  startedAt    DateTime? @db.DateTime(3)
  expiredAt    DateTime? @db.DateTime(3)
  createdAt    DateTime  @default(now()) @db.DateTime(3)
  updatedAt    DateTime  @updatedAt @db.DateTime(3)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([status, expiredAt])
}

model Feedback {
  id                  String            @id @db.VarChar(64)
  userId              String            @db.VarChar(64)
  contentCipher       String            @db.Text
  replyCipher         String?           @db.Text
  repliedAt           DateTime?         @db.DateTime(3)
  repliedBy           String?           @db.VarChar(64)
  status              String            @db.VarChar(32)
  isPublic            Boolean           @default(false)
  voteCount           Int               @default(0)
  aiModerationResult  Json?
  createdAt           DateTime          @default(now()) @db.DateTime(3)
  updatedAt           DateTime          @updatedAt @db.DateTime(3)
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  images              FeedbackImage[]
  votes               FeedbackVote[]
  comments            FeedbackComment[]

  @@index([userId, createdAt])
  @@index([status, isPublic, voteCount(sort: Desc)])
}

model FeedbackImage {
  id            String    @id @db.VarChar(64)
  feedbackId    String    @db.VarChar(64)
  url           String    @db.VarChar(512)
  compressedUrl String?   @db.VarChar(512)
  createdAt     DateTime  @default(now()) @db.DateTime(3)
  feedback      Feedback  @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@index([feedbackId])
}

model FeedbackVote {
  id         String   @id @db.VarChar(64)
  feedbackId String   @db.VarChar(64)
  userId     String   @db.VarChar(64)
  createdAt  DateTime @default(now()) @db.DateTime(3)
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([feedbackId, userId])
  @@index([feedbackId])
}

model FeedbackComment {
  id         String   @id @db.VarChar(64)
  feedbackId String   @db.VarChar(64)
  userId     String   @db.VarChar(64)
  content    String   @db.VarChar(500)
  createdAt  DateTime @default(now()) @db.DateTime(3)
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([feedbackId, createdAt])
}

model AiDailyQuota {
  id         String   @id @db.VarChar(128)
  userId     String   @db.VarChar(64)
  scope      String   @db.VarChar(32)
  dateKey    String   @db.VarChar(16)
  usedCount  Int      @default(0)
  limitCount Int
  createdAt  DateTime @default(now()) @db.DateTime(3)
  updatedAt  DateTime @updatedAt @db.DateTime(3)

  @@unique([userId, scope, dateKey])
  @@index([dateKey, scope])
}

model ProxyRequestLog {
  id               String   @id @db.VarChar(64)
  scope            String   @db.VarChar(32)
  endpoint         String   @db.VarChar(80)
  userId           String?  @db.VarChar(64)
  requestHash      String?  @db.VarChar(64)
  cacheHit         Boolean  @default(false)
  success          Boolean  @default(true)
  statusCode       Int      @default(200)
  durationMs       Int      @default(0)
  quotaCost        Int      @default(0)
  upstreamProvider String?  @db.VarChar(64)
  errorMessage     String?  @db.VarChar(500)
  createdAt        DateTime @default(now()) @db.DateTime(3)

  @@index([scope, createdAt])
  @@index([userId, createdAt])
}

model AppConfig {
  key       String   @id @db.VarChar(64)
  value     Json
  updatedAt DateTime @updatedAt @db.DateTime(3)

  @@index([updatedAt])
}

model ReminderConfig {
  id                String            @id @db.VarChar(64)
  enabled           Boolean           @default(false)
  reminderHour      Int               @default(9)
  reminderMinute    Int               @default(0)
  quietStartHour    Int               @default(22)
  quietStartMinute  Int               @default(0)
  quietEndHour      Int               @default(8)
  quietEndMinute    Int               @default(0)
  reminderText      String            @db.VarChar(255)
  lastTriggeredDate String?           @db.VarChar(32)
  updatedAt         DateTime          @updatedAt @db.DateTime(3)
  pushLogs          ReminderPushLog[]
}

model ReminderPushLog {
  id               String         @id @db.VarChar(64)
  reminderConfigId String         @db.VarChar(64)
  triggeredAt      DateTime       @default(now()) @db.DateTime(3)
  message          String         @db.VarChar(255)
  status           String         @db.VarChar(32)
  reminderConfig   ReminderConfig @relation(fields: [reminderConfigId], references: [id], onDelete: Cascade)

  @@index([triggeredAt])
}
